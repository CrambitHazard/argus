# Copy to ".env" and fill in. OpenRouter: https://openrouter.ai/keys

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: default max tokens for generate_text when not passed in code
# OPENROUTER_MAX_TOKENS=4096

# Optional: minimum read timeout (seconds) for OpenRouter; diary uses 300s floor, env can raise it
# OPENROUTER_TIMEOUT=600

# Optional (OpenRouter attribution)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Argus

# Diary file sign-off name (data/outputs/{date}_diary.md)
# DIARY_AUTHOR_NAME=Your Name
